# Postgres (Neon)
DATABASE_URL=

NODE_ENV=

NEXT_PUBLIC_BASE_URL=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# QStash (reservation expiry scheduler).
# Required in production. When unset, the cron endpoint falls back to CRON_SECRET.
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Local manual-testing bearer for /api/cron/release-expired.
# Ignored when QSTASH_CURRENT_SIGNING_KEY is set.
CRON_SECRET=
