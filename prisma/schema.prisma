generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
}

model Stock {
  productId String
  warehouseId String
  totalUnits Int
  reservedUnits Int @default(0)

  product Product @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@id([productId, warehouseId])
  @@index([warehouseId])
}

model Product {
  id String @id @default(cuid())
  sku String @unique
  name String
  createdAt DateTime @default(now())
  stocks Stock[]
}

model Warehouse {
  id String  @id @default(cuid())
  code String  @unique
  name String
  stocks Stock[]
}

model Reservation {
  id String @id @default(cuid())
  productId String
  warehouseId String
  quantity Int
  status ReservationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([productId, warehouseId])
}

model IdempotencyKey {
  key          String   @id
  endpoint     String
  requestHash  String
  statusCode   Int
  responseBody Json
  createdAt    DateTime @default(now())

  @@index([createdAt])
}